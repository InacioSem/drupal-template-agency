<?php

/**
 * @file
 * Primary module hooks for DrupalForge Business Core module.
 */

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_alter().
 */
function drupalforge_business_core_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  // Add placeholder text to search forms.
  if ($form_id === 'search_block_form') {
    $form['keys']['#attributes']['placeholder'] = t('Search...');
  }
}

/**
 * Implements hook_theme_suggestions_HOOK_alter() for node templates.
 */
function drupalforge_business_core_theme_suggestions_node_alter(array &$suggestions, array $variables): void {
  $node = $variables['elements']['#node'];
  $view_mode = $variables['elements']['#view_mode'];
  $suggestions[] = 'node__' . $node->bundle() . '__' . $view_mode;
}
