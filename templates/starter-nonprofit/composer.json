{
  "name": "drupalforge/starter-nonprofit",
  "description": "Warm, engaging Drupal 11 template for nonprofits, charities, and healthcare organizations",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "homepage": "https://drupalforge.dev",
  "support": {
    "docs": "https://drupalforge.dev/docs/getting-started",
    "issues": "https://github.com/drupalforge/starter-nonprofit/issues"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.3",
    "composer/installers": "^2.0",
    "drupal/core-recommended": "^11.0",
    "drupal/core-composer-scaffold": "^11.0",
    "drupal/core-project-message": "^11.0",
    "drupal/admin_toolbar": "^3.5",
    "drupal/gin": "^3.0",
    "drupal/paragraphs": "^1.18",
    "drupal/webform": "^6.2",
    "drupal/pathauto": "^1.13",
    "drupal/metatag": "^2.1",
    "drupal/simple_sitemap": "^4.2",
    "drupal/redirect": "^1.10",
    "drupal/config_split": "^2.0",
    "drupal/seckit": "^2.0",
    "drupal/honeypot": "^2.1",
    "drupal/eu_cookie_compliance": "^1.24",
    "drupal/focal_point": "^2.1",
    "drupal/scheduler": "^2.1",
    "drupal/linkit": "^6.1",
    "drupal/field_group": "^3.6",
    "drupal/entity_usage": "^2.0",
    "drupal/mailchimp": "^2.0",
    "drupal/social_media_links": "^2.9",
    "drupal/views_infinite_scroll": "^2.0",
    "drupal/geocoder": "^4.0",
    "drupal/geofield": "^1.58",
    "drupal/smart_date": "^4.1",
    "drupal/color_field": "^3.0",
    "drupal/easy_breadcrumb": "^2.0",
    "drush/drush": "^13.0"
  },
  "conflict": {
    "drupal/drupal": "*"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "drupal/core-composer-scaffold": true,
      "drupal/core-project-message": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  },
  "extra": {
    "drupal-scaffold": {
      "locations": {
        "web-root": "web/"
      }
    },
    "installer-paths": {
      "web/core": ["type:drupal-core"],
      "web/libraries/{$name}": ["type:drupal-library"],
      "web/modules/contrib/{$name}": ["type:drupal-module"],
      "web/profiles/contrib/{$name}": ["type:drupal-profile"],
      "web/themes/contrib/{$name}": ["type:drupal-theme"],
      "drush/Commands/contrib/{$name}": ["type:drupal-drush"]
    },
    "drupal-core-project-message": {
      "include-keys": ["homepage", "support"],
      "post-create-project-cmd-message": [
        "<bg=blue;fg=white>                                                     </>",
        "<bg=blue;fg=white>  DrupalForge Starter Nonprofit template created!    </>",
        "<bg=blue;fg=white>                                                     </>",
        "",
        "Next steps:",
        "  1. cd my-site",
        "  2. lando start",
        "  3. lando drush site:install --existing-config -y",
        "  4. lando drush recipe recipes/base",
        "",
        "Docs: https://drupalforge.dev/docs/getting-started"
      ]
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php -r \"copy('web/sites/default/default.settings.php', 'web/sites/default/settings.php');\""
    ]
  }
}
